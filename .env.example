# Required
OPENAI_API_KEY=your-openai-api-key

export HF_TOKEN=your-huggingface-token

# Optional: model selection
# OPENAI_MODEL=gpt-4o-mini

# Optional: custom base URL (e.g. for local models or proxies)
# OPENAI_BASE_URL=

# Optional: Azure OpenAI configuration
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# Optional: logging level (default: INFO)
# INFO  — high-signal events only: parse, feedback, PoC submit, tokens, memory
# DEBUG — adds mutation attempt results
# TRACE — everything: triage scores, taint path, compaction, tool output sizes
# LOG_LEVEL=INFO

# Optional: cross-task memory directory (default: /tmp/cybergym-memory)
# Use a path outside ~/Desktop, ~/Documents, ~/Pictures to avoid macOS permission prompts
# MEMORY_DIR=/tmp/cybergym-memory

{
  manifest_version: "0.2.0",

  program: {
    image: "ghcr.io/sharathbaddam/agentwhetters-cybergym-purple:latest",
    entrypoint: ["uv", "run", "src/server.py", "--host", "0.0.0.0", "--port", "9122"],

    env: {
      OPENAI_API_KEY: "${config.openai_api_key}",
      AZURE_OPENAI_ENDPOINT: {when: "config.azure_openai_endpoint", value: "${config.azure_openai_endpoint}"},
      AZURE_OPENAI_API_VERSION: {when: "config.azure_openai_api_version", value: "${config.azure_openai_api_version}"},
      AZURE_OPENAI_DEPLOYMENT: {when: "config.azure_openai_deployment", value: "${config.azure_openai_deployment}"},
      LOG_LEVEL: "INFO",
      PYTHONUNBUFFERED: "1",
      HF_TOKEN: {when: "config.hf_token", value: "${config.hf_token}"}
    },

    network: {
      endpoints: [
        { name: "endpoint", port: 9122 },
      ],
    },
  },

  config_schema: {
    type: "object",
    properties: {
      openai_api_key: { type: "string", secret: true },
      azure_openai_endpoint: { type: "string" },
      azure_openai_api_version: { type: "string" },
      azure_openai_deployment: { type: "string" },
      hf_token: { type: "string", secret: true }
    },
    required: ["openai_api_key"],
    additionalProperties: false,
  },

  provides: {
    a2a: { kind: "a2a", endpoint: "endpoint" },
  },

  exports: {
    a2a: "a2a",
  }
}
